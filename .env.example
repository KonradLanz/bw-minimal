# bw-minimal environment configuration
# Copy to .env and fill in values, OR point to your dotfiles env:
#
#   export KL_DOTFILES_ENV=~/git/dotfiles/env
#
# .env is gitignored. Never commit real credentials.
#
# Priority (highest wins):
#   1. Shell environment (already exported vars)
#   2. KL_DOTFILES_ENV file (dotfiles repo)
#   3. .env file (local override)
#   4. Interactive prompt at runtime

# ---------------------------------------------------------------------------
# Vaultwarden / Bitwarden server
# Self-hosted: https://vault.own.dedyn.io
# Bitwarden cloud: https://vault.bitwarden.com (default if unset)
# ---------------------------------------------------------------------------
BW_SERVER=https://vault.own.dedyn.io

# ---------------------------------------------------------------------------
# Account credentials
# Prefer leaving these unset and using interactive prompt or BW_SESSION.
# ---------------------------------------------------------------------------
# BW_EMAIL=you@example.com
# BW_MASTER=             ← never set in .env, use prompt

# ---------------------------------------------------------------------------
# Session token (set by: export BW_SESSION=$(bw unlock --raw))
# or:          export BW_SESSION=$(python3 bw_minimal.py unlock)
# ---------------------------------------------------------------------------
# BW_SESSION=

# ---------------------------------------------------------------------------
# Path to dotfiles env (auto-loaded if present)
# ---------------------------------------------------------------------------
# KL_DOTFILES_ENV=~/git/dotfiles/env
